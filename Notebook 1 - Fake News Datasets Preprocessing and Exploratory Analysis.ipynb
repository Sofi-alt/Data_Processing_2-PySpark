   "cell_type": "code",
   "execution_count": 1,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Importing the findspark module \n",
    "import findspark\n",
    "\n",
    "try:\n",
    "    # Initializing via the full spark path\n",
    "    findspark.init(\"/usr/local/spark/\")\n",
    "    \n",
    "except Exception as e:\n",
    "    print(f\"Could not initialize Spark environment: {e}\")\n",
