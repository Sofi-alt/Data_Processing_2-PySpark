     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Directory './data/processed_multi' has been deleted.\n"
     ]
    }
   ],
   "source": [
    "dir_path = './data/processed_multi' # path of the directory to be deleted, with our temporary file parts\n",
    "\n",
    "try: # checking if the directory exists before attempting deletion\n",
    "    \n",
    "    if os.path.exists(dir_path):\n",
    "        shutil.rmtree(dir_path)  # deleting the directory and all its contents\n",
    "        print(f\"Directory '{dir_path}' has been deleted.\")\n",
    "        \n",
    "    else:\n",
    "        print(f\"Directory '{dir_path}' does not exist.\") \n",
    "        \n",
    "except PermissionError: # handling cases where the script lacks permission to delete the directory\n",
    "    print(f\"Permission denied: Unable to delete the directory '{dir_path}'.\")\n",
    "    \n",
    "except OSError as e: # handling other OS-related errors \n",
    "    print(f\"Error deleting directory '{dir_path}': {e}\")\n",
    "    \n",
    "except Exception as e: # catch-all for any other unexpected exceptions\n",
    "    print(f\"Unexpected error occurred: {e}\")\n"
   ]
