     },
     "output_type": "display_data"
    }
   ],
   "source": [
    "# Grouping and counting labels\n",
    "label_counts = evaluation_df.groupBy(\"label\").count().orderBy(\"label\")\n",
    "\n",
    "# Collecting results as a list \n",
    "result = label_counts.collect()\n",
    "\n",
    "# Preparing data for plotting\n",
    "labels = [str(row['label']) for row in result]\n",
    "counts = [row['count'] for row in result]\n",
    "\n",
    "# Ploting\n",
    "plt.figure(figsize=(7,5))\n",
    "bars = plt.bar(labels, counts, color=[\"skyblue\", \"salmon\"])\n",
    "plt.xlabel(\"Label (0=True, 1=Fake)\")\n",
    "plt.ylabel(\"Count\")\n",
    "plt.title(\"Dataset Balance by Label\")\n",
    "\n",
    "# Adding counts on top of each bar in a single line\n",
    "for bar in bars:\n",
    "    plt.text(\n",
    "        bar.get_x() + bar.get_width() / 2,\n",
    "        bar.get_height(),\n",
    "        f'{int(bar.get_height())}',\n",
    "        ha='center', va='bottom'\n",
    "    )\n",
    "\n",
    "plt.show()"
   ]
